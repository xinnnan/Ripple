# =====================================================================
# Ripple — env template
# =====================================================================
# Copy to .env.local and fill in real values. .env.local is gitignored.
# Required for a working dev / e2e environment:
#   1. Supabase project (URL + new-format keys, see below)
#   2. Slack app (bot token + signing secret)
# Optional (system tolerates missing values, falls back gracefully):
#   3. AI provider key (mock fallback if blank/invalid)
#   4. Resend API key (email send silently skipped if blank)
# =====================================================================

# ---- Supabase --------------------------------------------------------
# New key format: sb_publishable_ (anon) + sb_secret_ (service role).
# Legacy SERVICE_ROLE_KEY / ANON_KEY envs are no longer used.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# ---- Slack -----------------------------------------------------------
# Bot User OAuth Token (xoxb-…) + Signing Secret from the Slack app config.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# ---- AI (Ripple Assist) ----------------------------------------------
# Provider: MiniMax AI (OpenAI-compatible).
# Leave MINIMAX_API_KEY blank to use the mock fallback (Sprint 2
# behavior). The /api/ai/suggest endpoint will return a structured
# mock response with confidence_level: "low" and metadata._mock: true.
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1/
MINIMAX_MODEL=M2.7-highspeed

# ---- Email (Resend) --------------------------------------------------
# Used by POST /api/tickets and PATCH /api/tickets/[id] on resolve.
# If blank, sends are silently skipped (ticket still creates / resolves).
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=support@dropletai.services

# ---- App -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
