# Supabase (New API Keys — use sb_publishable_ and sb_secret_ keys)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# AI (Ripple Assist)
OPENAI_API_KEY=sk-your-openai-key

# Email (Resend)
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=support@dropletai.services

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
